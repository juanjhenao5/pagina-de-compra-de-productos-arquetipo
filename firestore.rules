rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas Generales (Denegar por defecto)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: verificar si el usuario es admin
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // PRODUCTOS: Público para leer, solo admins para escribir (ISO 27001 A.8.2)
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // RESEÑAS: Público para leer, solo admins para escribir
    match /reviews/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // AJUSTES: Público para leer, solo admins para modificar
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // PEDIDOS: Usuarios autenticados pueden crear, admins gestionan (ISO 27001 A.8.2)
    match /orders/{id} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update, delete: if isAdmin();
    }
    
    // SUGERENCIAS: Cualquiera crea (formulario público), admins pueden leer/eliminar
    match /suggestions/{id} {
      allow create: if true;
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    // ADMINS: Solo lectura para usuarios autenticados (para verificar si son admin)
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
