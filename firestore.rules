rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas Generales (Denegar por defecto)
    match /{document=**} {
      allow read, write: if false;
    }

    // PRODUCTOS: Público para leer, validación estricta para escribir
    match /products/{id} {
      allow read: if true;
      allow write: if (request.resource != null && request.resource.data.name is string && request.resource.data.price is number)
                   || request.resource == null; // Permitir borrado
    }

    // RESEÑAS: Público para leer, requiere autenticación para escribir (ISO 27001 A.8.3)
    match /reviews/{id} { allow read: if true; allow write: if request.auth != null; }
    
    // AJUSTES: Público para leer, requiere autenticación para modificar
    match /settings/{id} { allow read: if true; allow write: if request.auth != null; }

    // PEDIDOS: Cualquiera crea, autenticados gestionan (ISO 27001 A.8.2)
    match /orders/{id} { allow create: if true; allow read: if request.auth != null; allow update, delete: if request.auth != null; }
    
    // SUGERENCIAS: Cualquiera crea, autenticados pueden leer/eliminar para gestión
    match /suggestions/{id} { allow create: if true; allow read, delete: if request.auth != null; allow update: if false; }
  }
}
